    + Headers
    
            Rest-Key: <Your-Rest-Key>
            Rest-Sign: <Your-Rest-Sign>
        
    + Body
    
            {
                "orderId": "565f2cdf-3f34-4881-bc80-46584c2c6b8d",
                "tonce": 1403076677349000
            }

+ Response 200 (application/json)

    + Body

            {
                "order": {
                    "buyTradedCurrency": true,
                    "executedAverageRate": null,
                    "limitPriceInSettlementCurrency": "3000.00000",
                    "orderId": "565f2cdf-3f34-4881-bc80-46584c2c6b8d",
                    "orderStatus": "ACTIVE",
                    "orderType": "LIMIT",
                    "replaceExistingOrderId": "eb7ebd89-0593-415e-b96b-d4d86cf35bb6",
                    "settlementCurrency": "HKD",
                    "settlementCurrencyAmount": null,
                    "settlementCurrencyAmountOutstanding": null,
                    "timestamp": 1403076674000,
                    "tradedCurrency": "BTC",
                    "tradedCurrencyAmount": "2.01",
                    "tradedCurrencyAmountOutstanding": "2.01",
                    "trades": []
                },
                "resultCode": "OK",
                "timestamp": 1403076677368
            }  
            
