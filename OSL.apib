                    "transactionType": "FILL_DEBIT",
                    "received": 1431004151000,
                    "processed": 1431004151000,
                    "timestampMillis": 1464677126478,
                    "displayTitle": "Order Fill",
                    "displayDescription": "Sell BTC @ 3231.23333 HKD / BTC"
                },
                {
                      "transactionClass": "MERCHANT",
                      "uuid": "14e425ff-655a-4fc9-a837-98485c1ae529",
                      "userUuid": "aadf3778-8233-4c24-99ca-ca9144025ec6",
                      "amount": -0.99000000,
                      "fee": 0E-8,
                      "balanceBefore": 0.0,
                      "balanceAfter": 0.0,
                      "ccy": "USD",
